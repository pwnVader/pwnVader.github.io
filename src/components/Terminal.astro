---
interface Props {
  title?: string;
}

const { title = 'pwnvader@kali' } = Astro.props;
---

<div class="terminal-window rounded-lg border border-border overflow-hidden"
     style="box-shadow: 0 0 30px rgba(126, 231, 135, 0.03), 0 4px 20px rgba(0, 0, 0, 0.4);">
  <!-- Title bar -->
  <div class="flex items-center gap-2 bg-bg-elevated px-4 py-2.5 border-b border-border">
    <div class="flex gap-1.5">
      <span class="w-3 h-3 rounded-full bg-[#f85149]"></span>
      <span class="w-3 h-3 rounded-full bg-[#d29922]"></span>
      <span class="w-3 h-3 rounded-full bg-[#3fb950]"></span>
    </div>
    <span class="ml-2 font-mono text-xs text-text-muted select-none">{title}</span>
  </div>
  <!-- Terminal body -->
  <div class="bg-bg-surface p-5 font-mono text-sm leading-relaxed">
    <slot />
  </div>
</div>
