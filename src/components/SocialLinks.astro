---
import { socialLinks } from '../data/social-links';
import { Icon } from 'astro-icon/components';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

{compact ? (
  <div class="flex flex-wrap gap-3">
    {socialLinks.map((link) => (
      <a
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        title={`${link.label} — ${link.handle}`}
        class={`flex items-center justify-center w-10 h-10 rounded-lg border border-border bg-bg-surface text-text-muted transition-all duration-300 transform hover:-translate-y-1 ${link.colorHoverClass}`}
      >
        <Icon name={link.icon} class="w-5 h-5" />
      </a>
    ))}
  </div>
) : (
  <div class="grid gap-2.5 sm:grid-cols-2">
    {socialLinks.map((link) => (
      <a
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        class={`group flex flex-col sm:flex-row items-start sm:items-center justify-between gap-1 sm:gap-4 rounded-lg border border-border bg-bg-surface px-4 py-3 transition-all duration-300 transform hover:-translate-y-1 overflow-hidden ${link.colorGroupClass.split(' ').slice(1).join(' ')}`}
      >
        <span class="flex items-center gap-2.5 whitespace-nowrap shrink-0">
          <Icon name={link.icon} class={`w-4 h-4 text-text-muted transition-colors ${link.colorGroupClass.split(' ')[0]}`} />
          <span class="font-mono text-sm font-medium text-text-primary transition-colors ${link.colorGroupClass.split(' ')[0]}">{link.label}</span>
        </span>
        <span class="font-mono text-xs text-text-muted truncate w-full sm:w-auto text-left sm:text-right">{link.handle} ↗</span>
      </a>
    ))}
  </div>
)}
