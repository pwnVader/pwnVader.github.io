---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
import { skillCategories } from '../../data/skills';

---

<BaseLayout
  title="Skills — pwnVader"
  description="Habilidades técnicas de pwnVader organizadas por categoría: Seguridad Ofensiva, Sistemas & Redes, IA & Automatización, Power Platform y CTFs."
>
  <section class="mx-auto max-w-5xl px-4 pt-16 pb-20">
    <!-- Page header -->
    <header class="mb-10 animate-fade-up">
      <h1 class="font-mono text-2xl sm:text-3xl font-bold text-text-primary">
        <span class="text-accent">~/</span>skills
      </h1>
      <p class="mt-2 font-mono text-sm text-text-secondary">
        <span class="text-accent/60">$</span> cat /proc/skills | sort --category
      </p>
    </header>

    <!-- Skills Grid -->
    <div class="grid gap-5 md:grid-cols-2">
      {skillCategories.map((category, catIdx) => (
        <div
          class="animate-fade-up rounded-lg border border-border bg-bg-surface overflow-hidden transition-all duration-300 hover:border-accent/30"
          style={`animation-delay: ${catIdx * 100}ms;`}
        >
          <!-- Category header -->
          <div class="flex items-center gap-3 px-5 py-3 border-b border-border bg-bg-elevated/50">
            <Icon name={category.icon} class={`w-5 h-5 ${category.colorClass}`} />
            <h2 class="font-mono text-sm font-bold text-text-primary">
              {category.title}
            </h2>
          </div>

          <!-- Terminal command -->
          <div class="px-5 pt-3 pb-1">
            <p class="font-mono text-xs text-text-muted">
              <span class={`${category.colorClass} opacity-70`}>$</span> {category.command}
            </p>
          </div>

          <!-- Skills list -->
          <ul class="px-5 pb-4 space-y-1.5">
            {category.skills.map((skill) => (
              <li class="flex items-center justify-between gap-3 font-mono text-sm">
                <span class="text-text-secondary flex items-center gap-2">
                  {skill.icon ? (
                    <Icon name={skill.icon} class={`w-3.5 h-3.5 ${category.colorClass} opacity-90`} />
                  ) : (
                    <span class={`text-[10px] pl-[1px] ${category.colorClass} opacity-70`}>▸</span>
                  )}
                  {skill.name}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    </div>
  </section>
</BaseLayout>
