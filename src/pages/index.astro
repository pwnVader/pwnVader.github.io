---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { Icon } from 'astro-icon/components';
---

<BaseLayout title="pwnVader — Pentester · Red Team · eJPTv2">
  <section class="mx-auto max-w-4xl px-4 pt-16 pb-20">
    <!-- Hero Terminal -->
    <div class="animate-fade-up">
      <Terminal title="pwnvader@kali — bash">
        <div class="space-y-1.5">
          <!-- cat readme.txt command -->
          <p>
            <span class="text-accent">pwnvader@kali</span><span class="text-border">:</span><span class="text-link">~</span><span class="text-border">$</span>
            <span class="ml-2 text-text-secondary">cat readme.txt</span>
          </p>

          <div class="h-2"></div>

          <!-- Identity block -->
          <div class="space-y-0.5">
            <p class="text-2xl sm:text-3xl font-bold text-text-primary leading-tight">
              Jesus P Romero
            </p>
            <p class="text-lg sm:text-xl font-bold text-accent">
              pwnVader
            </p>
          </div>

          <div class="h-2"></div>

          <!-- Tagline — unified with link color -->
          <div class="flex flex-wrap items-center gap-2">
            {[
              { label: 'Pentester', color: 'text-accent border-accent/20 bg-accent/10' },
              { label: 'Red Team', color: 'text-[#f85149] border-[#f85149]/20 bg-[#f85149]/10' },
              { label: 'eJPTv2', icon: 'cert-ejpt', color: 'text-[#a371f7] border-[#a371f7]/20 bg-[#a371f7]/10' },
              { label: 'Ing. Sistemas Computacionales', color: 'text-[#58a6ff] border-[#58a6ff]/20 bg-[#58a6ff]/10' },
            ].map((tag) => (
              <span class={`flex items-center gap-1.5 text-xs px-2.5 py-1 rounded border ${tag.color}`}>
                {tag.icon && <Icon name={tag.icon} class="w-4 h-4" />}
                {tag.label}
              </span>
            ))}
          </div>

          <div class="h-2"></div>

          <!-- Bio -->
          <p class="text-text-secondary text-sm leading-relaxed max-w-xl">
            Pentester especializado en seguridad ofensiva, mentoría técnica en
            comunidades como NicaSecurity y ponente en NetSentinel Academy sobre
            IA aplicada a la ciberseguridad. Certificado eJPTv2. Próximo objetivo: CPTS.
          </p>

          <div class="h-4"></div>

          <!-- Timeline / Experience -->
          <ul class="border-l border-border/60 ml-[5px] space-y-4 pt-1 pb-3">
            {[
              { date: 'Mar 2026', title: 'Technical Clinics: Road to eJPT: Lab Series', org: 'NicaSecurity' },
              { date: 'Ene 2026', title: 'Workshop Agentic Workflow: Tu Primer Entorno de Pentest con IA y MCP', org: 'NetSentinel Academy' },
              { date: 'Dic 2025', title: 'Internship Automatización y digitalización de auditoría de producto', org: 'Volkswagen' },
              { date: 'Nov 2025', title: 'Mentor', org: 'Nación Hacker' },
            ].map(exp => (
              <li class="relative pl-4">
                <span class="absolute -left-[4.5px] top-1.5 w-2 h-2 rounded-full border border-border bg-bg-surface"></span>
                <p class="font-mono text-[10px] text-text-muted">{exp.date}</p>
                <p class="text-sm text-text-primary mt-0.5 leading-snug">
                  <span class="text-accent/90">{exp.title}</span> 
                  <span class="text-text-muted mt-0.5 block sm:inline sm:ml-1">— {exp.org}</span>
                </p>
              </li>
            ))}
          </ul>

          <div class="h-3"></div>

          <!-- Prompt cursor -->
          <p class="flex items-center gap-1">
            <span class="text-accent">pwnvader@kali</span><span class="text-border">:</span><span class="text-link">~</span><span class="text-border">$</span>
            <span class="ml-2 text-text-muted animate-pulse">█</span>
          </p>
        </div>
      </Terminal>
    </div>

    <!-- CTA Buttons — Ghost Button style -->
    <div class="mt-8 flex flex-wrap gap-3 animate-fade-up" style="animation-delay: 150ms;">
      <a
        href="/skills/"
        class="rounded-lg border border-accent/40 px-5 py-2 font-mono text-sm text-accent transition-all hover:bg-accent/10 hover:border-accent"
      >
        ./skills.sh
      </a>
      <a
        href="/writeups/"
        class="rounded-lg border border-[#58a6ff]/40 px-5 py-2 font-mono text-sm text-[#58a6ff] transition-all hover:bg-[#58a6ff]/10 hover:border-[#58a6ff]"
      >
        ls writeups/
      </a>
      <a
        href="/linkedin/"
        class="rounded-lg border border-[#a371f7]/40 px-5 py-2 font-mono text-sm text-[#a371f7] transition-all hover:bg-[#a371f7]/10 hover:border-[#a371f7]"
      >
        cat community.txt
      </a>
    </div>

    <!-- Social Links Section -->
    <div class="mt-12 animate-fade-up" style="animation-delay: 300ms;">
      <h2 class="font-mono text-sm text-text-muted mb-4">
        <span class="text-accent/60">$</span> cat social_links.txt
      </h2>
      <SocialLinks />
    </div>

    <!-- Quick Stats — monochromatic dashboard -->
    <div class="mt-12 grid grid-cols-2 sm:grid-cols-4 gap-3 animate-fade-up" style="animation-delay: 450ms;">
      {[
        { value: 'eJPTv2', label: 'Certificación', icon: 'cert-ejpt', color: 'text-[#a371f7] group-hover:border-[#a371f7]/40' },
        { value: 'Top 1%', label: 'TryHackMe', icon: 'social-thm', color: 'text-[#d29922] group-hover:border-[#d29922]/40' },
        { value: '28.3K', label: 'TikTok', icon: 'social-tiktok', color: 'text-accent group-hover:border-accent/40' },
        { value: '2.2K', label: 'LinkedIn', icon: 'lucide:linkedin', color: 'text-[#58a6ff] group-hover:border-[#58a6ff]/40' },
      ].map((stat) => (
        <div class="group rounded-lg border border-border bg-bg-surface p-4 text-center transition-all">
          <p class={`flex items-center justify-center gap-2 font-mono text-lg font-bold ${stat.color.split(' ')[0]}`}>
            {stat.icon && <Icon name={stat.icon} class="w-5 h-5" />}
            {stat.value}
          </p>
          <p class="font-mono text-xs text-text-muted mt-2">{stat.label}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
