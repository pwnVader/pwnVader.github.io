---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — pwnVader" description="Página no encontrada.">
  <section class="mx-auto max-w-3xl px-4 py-20 flex flex-col items-center text-center">
    <!-- Glitch 404 -->
    <div class="relative mb-8">
      <h1 class="font-mono text-[8rem] sm:text-[10rem] font-bold text-accent/15 leading-none select-none">
        404
      </h1>
      <h1
        class="absolute inset-0 font-mono text-[8rem] sm:text-[10rem] font-bold text-accent leading-none animate-glow-pulse select-none"
        aria-hidden="true"
      >
        404
      </h1>
    </div>

    <!-- Error message -->
    <div class="font-mono text-sm space-y-2 mb-8">
      <p>
        <span class="text-accent/50">root@pwnvader</span><span class="text-border">:</span><span class="text-link/50">~</span><span class="text-border">#</span>
        <span class="ml-2 text-text-primary">Error: page not found</span>
      </p>
      <p class="text-text-secondary text-xs">
        The page you're looking for has been pwned or doesn't exist.
      </p>
    </div>

    <!-- ASCII art -->
    <pre class="font-mono text-[10px] sm:text-xs text-accent/20 mb-8 leading-tight select-none">{`
    ╔══════════════════════════════╗
    ║   ACCESS DENIED              ║
    ║   Segmentation fault (core   ║
    ║   dumped)                    ║
    ╚══════════════════════════════╝
    `}</pre>

    <!-- Return button — ghost style -->
    <a
      href="/"
      class="rounded-lg border border-accent/40 px-6 py-2.5 font-mono text-sm text-accent transition-all hover:bg-accent/10 hover:border-accent"
    >
      cd /home
    </a>
  </section>
</BaseLayout>
