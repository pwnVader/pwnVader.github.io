<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <rect width="1200" height="630" fill="#0d1117"/>
  <rect x="40" y="40" width="1120" height="550" rx="12" fill="#161b22" stroke="#30363d" stroke-width="1"/>
  <!-- Terminal dots -->
  <circle cx="80" cy="75" r="7" fill="#ff5f56"/>
  <circle cx="102" cy="75" r="7" fill="#ffbd2e"/>
  <circle cx="124" cy="75" r="7" fill="#27c93f"/>
  <text x="180" y="80" font-family="monospace" font-size="14" fill="#6e7681">pwnvader@kali — bash</text>
  <line x1="40" y1="100" x2="1160" y2="100" stroke="#30363d" stroke-width="1"/>
  <!-- Content -->
  <text x="80" y="200" font-family="monospace" font-size="48" font-weight="bold" fill="#e6edf3">Jesus P Romero</text>
  <text x="80" y="260" font-family="monospace" font-size="36" font-weight="bold" fill="#00ff41">pwnVader</text>
